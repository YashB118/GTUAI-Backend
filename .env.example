SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key
# JWT_SECRET: Supabase Dashboard → Settings → API → JWT Secret (REQUIRED)
JWT_SECRET=your_supabase_jwt_secret
BACKEND_URL=http://localhost:8000
# ALLOWED_ORIGINS: add your Vercel frontend URL in production
ALLOWED_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]

# Daily/D2 — Site URL (used by robots.ts + sitemap.ts). Set to deployed origin in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Phase 4 — Email (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Phase 5 — Monitoring (optional)
SENTRY_DSN=
